# ========================================================================
# ローカル開発用の環境変数サンプル。
# このファイルは Git にコミットしてよい。
# 実際の値は .env（.gitignoreで除外済）に記載する。
# ========================================================================

# --- DB ---
DB_ROOT_PASSWORD=rootpass

# --- Backend ---
ENV=local
LOG_LEVEL=DEBUG
DATABASE_URL=mysql+aiomysql://root:rootpass@db:3306/todos
CORS_ORIGINS=["http://localhost:5173"]
AUTH_MOCK_ENABLED=true

# --- Cognito (dev/prod 用、ローカルでは未使用) ---
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-northeast-1

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_AUTH_MOCK=true
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=
